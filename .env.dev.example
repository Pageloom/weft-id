POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
POSTGRES_DB=appdb
IS_DEV=True
BASE_DOMAIN=pageloom.localhost
DEFAULT_SUBDOMAIN=dev

# Email Configuration
SMTP_HOST=maildev
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_TLS=false
FROM_EMAIL=no-reply@pageloom.localhost

# Email backend: smtp, resend, or sendgrid
EMAIL_BACKEND=smtp
# RESEND_API_KEY=re_xxx
# SENDGRID_API_KEY=SG.xxx

# MFA Bypass (DEVELOPMENT ONLY - allows any 6-digit code)
BYPASS_OTP=false

# OpenAPI/Swagger Documentation
ENABLE_OPENAPI_DOCS=true

# Security
SESSION_SECRET_KEY=SESSION_SECRET_KEY
MFA_ENCRYPTION_KEY=YourBase64EncodedKeyHereMustBe32BytesBase64Encoded=

# Default tenant setup
DEV_SUBDOMAIN=dev
DEV_PASSWORD=devpass123
