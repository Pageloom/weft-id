# On-Prem Environment Configuration
# Copy this to .env and update values before starting
#
# {{DOMAIN}} will be replaced by onprem-setup.sh with your actual domain

# Database
POSTGRES_USER=appuser
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
POSTGRES_DB=appdb

# Application
IS_DEV=False
BASE_DOMAIN={{DOMAIN}}
DEFAULT_SUBDOMAIN=dev

# Email Configuration (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TLS=true
FROM_EMAIL=no-reply@{{DOMAIN}}

# Email backend: smtp, resend, or sendgrid
# Use resend or sendgrid if SMTP ports (25, 465, 587) are blocked
EMAIL_BACKEND=smtp

# For Resend backend (https://resend.com)
# RESEND_API_KEY=re_xxx

# For SendGrid backend (https://sendgrid.com)
# SENDGRID_API_KEY=SG.xxx

# MFA Bypass (allows any 6-digit code - use for initial setup only)
# WARNING: Disable this after setting up email delivery!
BYPASS_OTP=false

# Security (CHANGE THESE IN PRODUCTION!)
SESSION_SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET_KEY
MFA_ENCRYPTION_KEY=CHANGE_ME_TO_BASE64_ENCODED_32_BYTE_KEY

# Default tenant setup (used by dev-docker-entrypoint.sh)
DEV_SUBDOMAIN=dev
DEV_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
