#!/usr/bin/env bash
# Run SAML E2E tests (requires Docker services running)
# Usage: ./test-e2e [pytest args]
#
# Examples:
#   ./test-e2e                          # Run all E2E tests
#   ./test-e2e --headed --slowmo=500    # Debug in visible browser
#   ./test-e2e -k test_sp_initiated     # Run specific test
#   ./test-e2e --tb=long                # Verbose tracebacks

exec poetry run python -m pytest tests/e2e/ -n 0 -v --tb=short "$@"
