# =============================================================================
# WeftID — Production Configuration
# =============================================================================
# Copy this file to .env and fill in all required values before starting.
#
#   cp .env.production.example .env
#   # Edit .env, then:
#   docker compose up -d

# -----------------------------------------------------------------------------
# Version
# -----------------------------------------------------------------------------
# Pin to a specific release tag for stability (e.g., 1.0.0).
WEFT_VERSION=latest

# -----------------------------------------------------------------------------
# Domain (required)
# -----------------------------------------------------------------------------
# Your root domain. Tenants are accessed via subdomains (tenant.id.example.com).
# DNS must point both the apex and wildcard (*.id.example.com) to this server.
BASE_DOMAIN=

# -----------------------------------------------------------------------------
# Secrets (required)
# -----------------------------------------------------------------------------
# Generate each with:  openssl rand -base64 32
SECRET_KEY=
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# Email / SMTP (required for invitations, MFA codes, and notifications)
# -----------------------------------------------------------------------------
# Option 1: SMTP (default)
EMAIL_BACKEND=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TLS=true
FROM_EMAIL=

# Option 2: SendGrid (uncomment and fill in, set EMAIL_BACKEND=sendgrid)
# EMAIL_BACKEND=sendgrid
# SENDGRID_API_KEY=

# Option 3: Resend (uncomment and fill in, set EMAIL_BACKEND=resend)
# EMAIL_BACKEND=resend
# RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
ENABLE_OPENAPI_DOCS=false
