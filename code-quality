#!/usr/bin/env bash
# Run all code quality checks (same as the Code Quality CI workflow)
# Usage: ./code-quality [--fix]
#
# Options:
#   --fix    Auto-fix lint and formatting issues instead of just checking
#
# Examples:
#   ./code-quality        # Check everything (CI-equivalent)
#   ./code-quality --fix  # Fix lint/format, then check types and compliance

set -e

FIX=false
if [[ "$1" == "--fix" ]]; then
    FIX=true
fi

echo "=== Lint ==="
if $FIX; then
    poetry run ruff check --fix app/ tests/
else
    poetry run ruff check app/ tests/
fi

echo ""
echo "=== Formatting ==="
if $FIX; then
    poetry run ruff format app/ tests/
else
    poetry run ruff format --check app/ tests/
fi

echo ""
echo "=== Type Check ==="
poetry run python -m mypy app/

echo ""
echo "=== Compliance Check ==="
python scripts/compliance_check.py

echo ""
echo "=== Dependency Security ==="
python scripts/deps_check.py
