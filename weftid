#!/bin/sh
# WeftID management script
#
# Wraps common docker compose operations into simple subcommands.
# Generated by install.sh alongside docker-compose.yml.
#
# Usage:
#   ./weftid help         Show all commands
#   ./weftid up           Start services
#   ./weftid backup       Full backup (roles, data, storage)
#   ./weftid tenant       Provision a new tenant interactively
#   ./weftid upgrade      Upgrade to a new version
#   ./weftid rollback     Roll back to the previous version
#
# Prerequisites: docker, curl, POSIX shell
# Works on Linux and macOS.

set -e

GHCR_IMAGE="ghcr.io/pageloom/weft-id"
GITHUB_API="https://api.github.com/repos/pageloom/weft-id"

# --- Helpers ---------------------------------------------------------------

die() { printf "Error: %s\n" "$1" >&2; exit 1; }

prompt() {
    printf "%s" "$1"
    read -r REPLY
}

confirm() {
    prompt "$1 [y/N] "
    case "$REPLY" in
        [yY]*) return 0 ;;
        *) return 1 ;;
    esac
}

require_docker() {
    command -v docker >/dev/null 2>&1 || die "docker is required but not installed."
    docker compose version >/dev/null 2>&1 || die "docker compose v2 is required."
}

today() {
    date +%Y%m%d
}

current_version() {
    if [ -f .env ]; then
        grep '^WEFT_VERSION=' .env | cut -d= -f2
    fi
}

compose_volume() {
    # Resolve the full Docker volume name for a compose-defined volume.
    # Usage: compose_volume dbdata
    docker volume ls -q --filter "name=_${1}$" | head -1
}

validate_version() {
    # Ensure a version string contains only digits and dots (e.g., 1.2.3).
    case "$1" in
        *[!0-9.]*) die "Version must contain only digits and dots (e.g., 1.2.0)" ;;
        .* | *. ) die "Version must not start or end with a dot" ;;
        "") die "Version is required" ;;
    esac
}

wait_healthy() {
    # Wait for core services to be healthy. Timeout after 90 seconds.
    echo ""
    echo "Waiting for services to be healthy..."
    timeout=90
    elapsed=0
    while [ "$elapsed" -lt "$timeout" ]; do
        # Check health of services that have healthchecks (app, db, memcached)
        app_health=$(docker compose ps --format json 2>/dev/null \
            | grep -o '"Health":"[^"]*"' | head -1 | cut -d'"' -f4 || echo "unknown")

        # docker compose ps --format json may output one JSON per line or a JSON array
        # depending on version. Fall back to parsing table output.
        if [ "$app_health" = "unknown" ]; then
            app_health=$(docker compose ps app 2>/dev/null | tail -1 | grep -o '(healthy)' || echo "")
            [ -n "$app_health" ] && app_health="healthy"
        fi

        if [ "$app_health" = "healthy" ]; then
            echo ""
            docker compose ps --format "table {{.Service}}\t{{.Status}}" 2>/dev/null \
                || docker compose ps
            echo ""
            echo "All services up."
            return 0
        fi

        sleep 3
        elapsed=$((elapsed + 3))
        printf "  ... %ds\n" "$elapsed"
    done

    echo ""
    echo "Warning: Services did not become healthy within ${timeout}s."
    echo "Check ./weftid status and ./weftid logs for details."
    docker compose ps
    return 1
}

# --- Subcommands -----------------------------------------------------------

cmd_up() {
    require_docker
    docker compose up -d
    wait_healthy
}

cmd_down() {
    require_docker
    docker compose down
}

cmd_restart() {
    require_docker
    docker compose restart
}

cmd_status() {
    require_docker
    docker compose ps
}

cmd_logs() {
    require_docker
    if [ -n "$1" ]; then
        docker compose logs -f "$1"
    else
        docker compose logs -f
    fi
}

cmd_version() {
    if [ -f .env ]; then
        version=$(grep '^WEFT_VERSION=' .env | cut -d= -f2)
        echo "WeftID version: ${version:-unknown}"
    else
        die ".env file not found"
    fi
}

cmd_shell() {
    require_docker
    docker compose exec app bash
}

cmd_migrate_status() {
    require_docker
    docker compose exec db \
        psql -U postgres -d appdb \
        -c "SELECT version, status, started_at, completed_at FROM schema_migration_log ORDER BY id"
}

cmd_email() {
    address="$1"
    if [ -z "$address" ]; then
        prompt "Email address to test: "
        address="$REPLY"
    fi
    [ -z "$address" ] && die "Email address is required"

    require_docker
    docker compose exec app python -m app.cli.verify_email --to "$address"
}

# --- Tenant provisioning ---------------------------------------------------

validate_subdomain() {
    value="$1"
    [ -z "$value" ] && { echo "Subdomain is required."; return 1; }

    # Length check
    len=$(printf "%s" "$value" | wc -c | tr -d ' ')
    [ "$len" -gt 63 ] && { echo "Subdomain too long (max 63 characters)."; return 1; }

    # Format: lowercase alphanumeric and hyphens, no leading/trailing hyphen
    case "$value" in
        -*|*-) echo "Subdomain cannot start or end with a hyphen."; return 1 ;;
    esac
    cleaned=$(printf "%s" "$value" | tr -cd 'a-z0-9-')
    [ "$cleaned" != "$value" ] && {
        echo "Subdomain must be lowercase letters, numbers, and hyphens only."
        return 1
    }
    return 0
}

validate_tenant_name() {
    value="$1"
    [ -z "$value" ] && { echo "Tenant name is required."; return 1; }
    len=$(printf "%s" "$value" | wc -c | tr -d ' ')
    [ "$len" -gt 30 ] && { echo "Tenant name too long (max 30 characters)."; return 1; }
    return 0
}

validate_email() {
    value="$1"
    [ -z "$value" ] && { echo "Email is required."; return 1; }
    case "$value" in
        *@*.*) return 0 ;;
        *) echo "Invalid email address."; return 1 ;;
    esac
}

validate_name() {
    label="$1"
    value="$2"
    [ -z "$value" ] && { echo "${label} is required."; return 1; }
    len=$(printf "%s" "$value" | wc -c | tr -d ' ')
    [ "$len" -gt 255 ] && { echo "${label} too long (max 255 characters)."; return 1; }
    return 0
}

prompt_validated() {
    # Usage: prompt_validated "Label: " validator [validator_args...]
    label="$1"; shift
    validator="$1"; shift
    while true; do
        prompt "$label"
        err=$($validator "$REPLY" "$@" 2>&1) && break
        echo "  $err"
    done
}

cmd_tenant() {
    echo ""
    echo "Provision a new tenant"
    echo "======================"
    echo ""

    prompt_validated "Subdomain: " validate_subdomain
    subdomain="$REPLY"

    prompt_validated "Tenant name: " validate_tenant_name
    tenant_name="$REPLY"

    prompt_validated "Super admin email: " validate_email
    email="$REPLY"

    prompt_validated "First name: " validate_name "First name"
    first_name="$REPLY"

    prompt_validated "Last name: " validate_name "Last name"
    last_name="$REPLY"

    echo ""
    echo "Summary:"
    echo "  Subdomain:   $subdomain"
    echo "  Tenant:      $tenant_name"
    echo "  Admin:       $first_name $last_name ($email)"
    echo ""

    if ! confirm "Proceed?"; then
        echo "Aborted."
        exit 0
    fi

    require_docker
    docker compose exec app python -m app.cli.provision_tenant \
        --subdomain "$subdomain" \
        --tenant-name "$tenant_name" \
        --email "$email" \
        --first-name "$first_name" \
        --last-name "$last_name"
}

# --- Backup -----------------------------------------------------------------

cmd_backup() {
    require_docker
    stamp=$(today)
    ver=$(current_version)
    tag="${ver:-unknown}-${stamp}"

    # Restrict backup file permissions (owner-only) since dumps contain
    # password hashes, session data, and PII.
    umask 077

    echo ""
    echo "WeftID Backup (version ${ver:-unknown})"
    echo "=============="
    echo ""

    # Roles
    echo "Backing up database roles..."
    docker compose exec -T db \
        pg_dumpall -U postgres --roles-only > "roles-${tag}.sql" \
        || die "Failed to back up roles"
    echo "  roles-${tag}.sql"

    # Data
    echo "Backing up database data..."
    docker compose exec -T db \
        pg_dump -U postgres appdb > "backup-${tag}.sql" \
        || die "Failed to back up data"
    echo "  backup-${tag}.sql"

    # Storage
    echo "Backing up file storage..."
    storage_vol=$(compose_volume storage)
    if [ -n "$storage_vol" ]; then
        docker run --rm \
            -v "${storage_vol}:/data" \
            -v "$(pwd):/backup" \
            alpine tar czf "/backup/storage-${tag}.tar.gz" -C /data . \
            || die "Failed to back up storage"
        echo "  storage-${tag}.tar.gz"
    else
        echo "  (no storage volume found, skipped)"
    fi

    echo ""
    echo "Backup complete."
}

# --- Upgrade ----------------------------------------------------------------

check_version_exists() {
    version="$1"
    # Check GitHub releases for the tag
    status=$(curl -s -o /dev/null -w "%{http_code}" \
        "${GITHUB_API}/releases/tags/v${version}")
    [ "$status" = "200" ]
}

check_today_backup() {
    stamp=$(today)
    # Match versioned backup files from today (e.g., roles-1.0.4-20260321.sql)
    for f in roles-*-"${stamp}".sql; do
        [ -f "$f" ] && break
        return 1
    done
    for f in backup-*-"${stamp}".sql; do
        [ -f "$f" ] && return 0
    done
    return 1
}

cmd_upgrade() {
    [ -f .env ] || die ".env file not found"

    current=$(current_version)
    echo ""
    echo "WeftID Upgrade"
    echo "==============="
    echo ""
    echo "Current version: ${current:-unknown}"
    echo ""

    prompt "Target version (e.g., 1.2.0): "
    target="$REPLY"
    validate_version "$target"

    # Validate the version exists
    echo "Checking version ${target}..."
    if ! check_version_exists "$target"; then
        die "Version ${target} not found. Check available releases at https://github.com/pageloom/weft-id/releases"
    fi
    echo "  Version ${target} exists."

    # Check for today's backup
    if ! check_today_backup; then
        echo ""
        echo "Warning: No backup from today found."
        echo "It is strongly recommended to run ./weftid backup before upgrading."
        echo ""
        if ! confirm "Continue without a backup?"; then
            echo "Aborted. Run ./weftid backup first."
            exit 0
        fi
    fi

    # Record current version for rollback
    if [ -n "$current" ]; then
        echo "$current" >> .previous_versions
        echo "  Recorded ${current} in .previous_versions"
    fi

    # Update .env
    if [ -n "$current" ]; then
        sed -i.bak "s|^WEFT_VERSION=.*|WEFT_VERSION=${target}|" .env && rm -f .env.bak
    else
        echo "WEFT_VERSION=${target}" >> .env
    fi
    echo "  Updated WEFT_VERSION to ${target} in .env"

    # Pull and restart
    echo ""
    require_docker
    echo "Pulling new images..."
    docker compose pull
    echo "Restarting services..."
    docker compose up -d

    if wait_healthy; then
        echo "Upgrade to ${target} complete."
    else
        echo "Upgrade to ${target} finished but services may not be healthy."
    fi
    echo "If something goes wrong, run ./weftid rollback to roll back."
}

# --- Rollback ---------------------------------------------------------------

find_latest_backup() {
    # Find the most recent backup files for a given version.
    # Sets ROLLBACK_ROLES, ROLLBACK_DATA, and ROLLBACK_STORAGE (may be empty).
    ver="$1"
    ROLLBACK_ROLES=""
    ROLLBACK_DATA=""
    ROLLBACK_STORAGE=""

    # Sort by filename (date stamp sorts naturally) and take the last match
    for f in roles-"${ver}"-*.sql; do
        [ -f "$f" ] && ROLLBACK_ROLES="$f"
    done
    for f in backup-"${ver}"-*.sql; do
        [ -f "$f" ] && ROLLBACK_DATA="$f"
    done
    for f in storage-"${ver}"-*.tar.gz; do
        [ -f "$f" ] && ROLLBACK_STORAGE="$f"
    done
}

cmd_rollback() {
    [ -f .env ] || die ".env file not found"
    require_docker

    current=$(current_version)

    if [ ! -f .previous_versions ]; then
        die "No upgrade history found. Nothing to roll back."
    fi

    previous=$(tail -1 .previous_versions)
    [ -z "$previous" ] && die "No previous version found in .previous_versions"
    validate_version "$previous"

    # Find backup files for the previous version
    find_latest_backup "$previous"

    if [ -z "$ROLLBACK_ROLES" ] || [ -z "$ROLLBACK_DATA" ]; then
        echo ""
        echo "No backup files found for version ${previous}."
        echo ""
        echo "Expected files matching: roles-${previous}-YYYYMMDD.sql"
        echo "                         backup-${previous}-YYYYMMDD.sql"
        echo ""
        echo "Run ./weftid backup before upgrading, or restore manually."
        die "Cannot roll back without backup files."
    fi

    echo ""
    echo "======================================================================"
    echo "  WEFTID ROLLBACK"
    echo "======================================================================"
    echo ""
    echo "  Current version:  ${current:-unknown}"
    echo "  Rolling back to:  ${previous}"
    echo ""
    echo "  Backup files:"
    echo "    Roles:   ${ROLLBACK_ROLES}"
    echo "    Data:    ${ROLLBACK_DATA}"
    if [ -n "$ROLLBACK_STORAGE" ]; then
        echo "    Storage: ${ROLLBACK_STORAGE}"
    else
        echo "    Storage: (none found, will not restore file storage)"
    fi
    echo ""
    echo "======================================================================"
    echo "  WARNING: THIS IS A DESTRUCTIVE OPERATION"
    echo "======================================================================"
    echo ""
    echo "  This will:"
    echo ""
    echo "    1. Stop all services"
    echo "    2. DELETE the current database volume (all data)"
    echo "    3. Recreate the database from the backup files above"
    echo "    4. Restart all services on version ${previous}"
    echo ""
    echo "  ANY DATA CREATED OR CHANGED SINCE THE BACKUP WILL BE LOST."
    echo "  This includes users, tenants, settings, and audit logs"
    echo "  added after the backup was taken."
    echo ""
    echo "  This action cannot be undone."
    echo ""
    echo "======================================================================"
    echo ""

    prompt "Type 'rollback' to confirm: "
    if [ "$REPLY" != "rollback" ]; then
        echo "Aborted."
        exit 0
    fi

    echo ""

    # 1. Stop all services
    echo "Stopping all services..."
    docker compose down

    # 2. Remove the database volume
    echo "Removing database volume..."
    db_vol=$(compose_volume dbdata)
    if [ -n "$db_vol" ]; then
        docker volume rm "$db_vol"
    else
        echo "  (no dbdata volume found, proceeding)"
    fi

    # 3. Set version back
    sed -i.bak "s|^WEFT_VERSION=.*|WEFT_VERSION=${previous}|" .env && rm -f .env.bak
    echo "  Set WEFT_VERSION to ${previous} in .env"

    # 4. Start database only (applies baseline schema)
    echo "Starting database..."
    docker compose up -d db
    echo "  Waiting for database to be ready..."
    attempts=0
    while ! docker compose exec -T db pg_isready -U postgres >/dev/null 2>&1; do
        attempts=$((attempts + 1))
        if [ "$attempts" -ge 30 ]; then
            die "Database did not become ready within 30 seconds"
        fi
        sleep 1
    done

    # 5. Restore roles and data
    echo "Restoring roles from ${ROLLBACK_ROLES}..."
    docker compose exec -T db psql -U postgres < "$ROLLBACK_ROLES" \
        || die "Failed to restore roles"

    echo "Restoring data from ${ROLLBACK_DATA}..."
    docker compose exec -T db psql -U postgres appdb < "$ROLLBACK_DATA" \
        || die "Failed to restore data"

    # 6. Restore storage if available
    if [ -n "$ROLLBACK_STORAGE" ]; then
        echo "Restoring file storage from ${ROLLBACK_STORAGE}..."
        storage_vol=$(compose_volume storage)
        if [ -n "$storage_vol" ]; then
            docker run --rm \
                -v "${storage_vol}:/data" \
                -v "$(pwd):/backup" \
                alpine sh -c "rm -rf /data/* && tar xzf /backup/${ROLLBACK_STORAGE} -C /data" \
                || die "Failed to restore storage"
        else
            echo "  (no storage volume found, skipping storage restore)"
        fi
    fi

    # 7. Remove the last entry from .previous_versions
    lines=$(wc -l < .previous_versions | tr -d ' ')
    if [ "$lines" -le 1 ]; then
        rm -f .previous_versions
    else
        head -n $((lines - 1)) .previous_versions > .previous_versions.tmp
        mv .previous_versions.tmp .previous_versions
    fi

    # 8. Start all services
    echo "Starting all services on version ${previous}..."
    docker compose up -d

    if wait_healthy; then
        echo "Rollback to ${previous} complete."
    else
        echo "Rollback to ${previous} finished but services may not be healthy."
        echo "Check ./weftid logs for details."
    fi
}

# --- Help -------------------------------------------------------------------

cmd_help() {
    cat <<'HELPEOF'
WeftID Management

Usage: ./weftid <command> [args]

Commands:
  up                Start all services
  down              Stop all services
  restart           Restart all services
  status            Show service status
  logs [service]    Tail logs (all services, or a specific one)
  version           Show the running WeftID version
  email [address]   Verify email deliverability
  tenant            Provision a new tenant (interactive)
  backup            Full backup (database roles, data, and file storage)
  upgrade           Upgrade to a new version (interactive)
  rollback          Roll back to the previous version after an upgrade
  migrate-status    Show database migration log
  shell             Open a shell in the app container
  help              Show this help message
HELPEOF
}

# --- Dispatch ---------------------------------------------------------------

command="$1"
shift 2>/dev/null || true

case "$command" in
    up)              cmd_up ;;
    down)            cmd_down ;;
    restart)         cmd_restart ;;
    status)          cmd_status ;;
    logs)            cmd_logs "$@" ;;
    version)         cmd_version ;;
    email)           cmd_email "$@" ;;
    tenant)          cmd_tenant ;;
    backup)          cmd_backup ;;
    upgrade)         cmd_upgrade ;;
    rollback)        cmd_rollback ;;
    migrate-status)  cmd_migrate_status ;;
    shell)           cmd_shell ;;
    help|--help|-h)  cmd_help ;;
    "")              cmd_help ;;
    *)               echo "Unknown command: $command"; echo ""; cmd_help; exit 1 ;;
esac
